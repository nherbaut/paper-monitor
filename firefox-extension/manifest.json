{
  "manifest_version": 3,
  "name": "Paper Monitor PDF Capture",
  "version": "0.1.0",
  "description": "Captures authenticated provider PDF downloads and attaches them to Paper Monitor.",
  "permissions": [
    "notifications",
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://papers.home.nextnet.top/*",
        "http://localhost:8080/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Paper Monitor PDF Capture"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf-capture@paper-monitor.nextnet.top",
      "strict_min_version": "121.0"
    }
  }
}
